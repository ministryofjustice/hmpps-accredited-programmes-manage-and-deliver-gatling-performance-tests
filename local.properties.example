# Copy this file to local.properties and fill in the values.
#
# Every setting is resolved in this order of precedence:
#   1. JVM system property        -Ddb_port=5433
#   2. Environment variable       key in UPPER_SNAKE_CASE, e.g. db_port -> DB_PORT
#   3. This file                  db_port=5433
# So anything set here can still be overridden per-run from the command line or CI.

# Target environment
protocol=https
domain=accredited-programmes-manage-and-deliver-dev.hmpps.service.justice.gov.uk

# Database — values come from the port-forward setup (see README "Prep for running load test")
db_port=
db_name=
db_username=
db_password=

auth_username=
auth_password=

# Optional: HMPPS Auth base URL (defaults to the dev sign-in service)
#authBaseUrl=https://sign-in-dev.hmpps.service.justice.gov.uk

# Optional debug override: reuse an existing session cookie (copied from the browser) instead of
# signing in. If set, the sign-in step is skipped and ALL virtual users share this one session.
#hmpps-accredited-programmes-manage-and-deliver-ui.session=

# Optional load overrides (defaults shown)
#case_list_concurrent_users=2
#case_list_test_duration_minutes=5
#create_group_concurrent_users=1
#create_group_test_duration_minutes=5
#schedule_overview_concurrent_users=5
#schedule_overview_test_duration_minutes=5

# --- Running against the LOCAL docker-compose stack (see Makefile / README) ---
# To point the tests at the local stack instead of the dev environment, use these values instead of
# the ones at the top of this file:
#protocol=http
#domain=localhost:3000
#authBaseUrl=http://localhost:8090
#db_port=5432
#db_name=postgres
#db_username=admin
#db_password=admin_password
# A dev user that exists in the local hmpps-auth AND has the region/roles matching your seeded data
# and the region in GroupAllocationFeeder (currently 'Greater Manchester'):
#auth_username=
#auth_password=
